{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/analyze.ts": {
      "maxDuration": 120
    },
    "api/upload.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/src/(.*)", "destination": "/src/$1" },
    { "source": "/@(.*)", "destination": "/@$1" },
    { "source": "/node_modules/(.*)", "destination": "/node_modules/$1" },
    { "source": "/((?!api/|src/|@|node_modules/).+\\.[^.]+)", "destination": "/$1" },
    { "source": "/((?!api/|src/|@|node_modules/).*)", "destination": "/index.html" }
  ]
}
